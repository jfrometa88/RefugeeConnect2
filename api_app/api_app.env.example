# =============================================================================
# RefugeeConnect AI — API app secrets
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# =============================================================================

# Google Gemini API key (required when INFERENCE_MODE=google)
GOOGLE_API_KEY=your_google_api_key_here

# Inference mode — mirrors root .env, used inside the app logic
# Values: "google" | "ollama"
INFERENCE_MODE=google

# Ollama model to use (mirrors root .env, used inside the app logic)
OLLAMA_MODEL=gemma3:12b

# OLLAMA_HOST is injected by docker-compose from the root .env
# No need to set it here unless running outside Docker
# OLLAMA_HOST=http://localhost:11434
