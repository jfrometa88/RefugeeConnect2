# =============================================================================
# RefugeeConnect AI — Root environment configuration
# Copy this file to .env and fill in your values
# This file controls Docker-level settings (not app secrets)
# App secrets (API keys, etc.) go in api_app/.env and dash_app/.env
# =============================================================================


# =============================================================================
# INFERENCE MODE
# Controls whether the app uses Google API or local Ollama
# Values: "google" | "ollama"
# =============================================================================
INFERENCE_MODE=google


# =============================================================================
# OLLAMA HOST — where the api_app container reaches Ollama
#
# SCENARIO 1: Local development (Ollama running on your host machine)
#   → Keep default, no change needed
#   → Run with: docker compose up
#
# SCENARIO 2a: Friend's machine, Ollama on host (same as scenario 1)
#   → Keep default, no change needed
#   → Run with: docker compose up
#
# SCENARIO 2b: Friend's machine, Ollama containerized (GPU available)
#   → Change to: OLLAMA_HOST=http://ollama:11434
#   → Run with: docker compose --profile ollama up
#
# SCENARIO 3: Hugging Face Spaces
#   → Set INFERENCE_MODE=google, OLLAMA_HOST is ignored
#   → Use only a single Dockerfile (no compose)
# =============================================================================
OLLAMA_HOST=http://host.docker.internal:11434


# =============================================================================
# OLLAMA MODEL
# The model that will be used when INFERENCE_MODE=ollama
# Examples: "gemma3:12b", "qwen2.5:7b", "llama3.2:3b"
# =============================================================================
OLLAMA_MODEL=gemma3:12b
